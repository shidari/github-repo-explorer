{
  "name": "github-repo-explorer",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.1",
  "scripts": {
    "dev": "next dev",
    "dev:api": "pnpm exec tsx --tsconfig tsconfig.json --watch src/app/api/_local/server.ts",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "lint": "biome check",
    "format": "biome format --write",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "codegen:db": "bash src/infra/scripts/codegen.sh"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.3.16",
    "@hono/effect-validator": "^1.2.0",
    "@hono/node-server": "^1.19.11",
    "@hono/standard-validator": "^0.2.2",
    "@hono/swagger-ui": "^0.6.1",
    "@octokit/rest": "^22.0.1",
    "effect": "^3.19.19",
    "hono": "^4.12.7",
    "hono-openapi": "^1.3.0",
    "kysely": "^0.28.12",
    "kysely-codegen": "^0.20.0",
    "kysely-pglite": "^0.6.1",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "swr": "^2.4.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@chromatic-com/storybook": "^5.0.1",
    "@faker-js/faker": "^10.3.0",
    "@storybook/addon-a11y": "^10.2.19",
    "@storybook/addon-docs": "^10.2.19",
    "@storybook/addon-onboarding": "^10.2.19",
    "@storybook/addon-vitest": "^10.2.19",
    "@storybook/nextjs-vite": "^10.2.19",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/browser-playwright": "4.1.0",
    "@vitest/coverage-v8": "4.1.0",
    "babel-plugin-react-compiler": "1.0.0",
    "playwright": "^1.58.2",
    "storybook": "^10.2.19",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
